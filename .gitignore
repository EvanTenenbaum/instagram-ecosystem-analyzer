# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Data directories
data/raw/*.json
data/manual/screenshots/*
!data/manual/screenshots/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Outputs
outputs/*
!outputs/.gitkeep

# Logs
logs/*
!logs/.gitkeep
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Session data
data/.session_cookies.json

# Test data
tests/fixtures/*.json
!tests/fixtures/.gitkeep
!tests/fixtures/sample_instagram_data.json

# Local credentials (never commit)
.env
.env.*
credentials.json

# Browser profile (contains session cookies and Chrome cache — never commit)
data/.browser_profile/

# Raw data subdirectories (collected Instagram data — never commit)
data/raw/*/

# Processed data (generated — never commit)
data/processed/*/

# Outputs (generated — regenerate from data)
outputs/
